{
  "version": 2,
  "builds": [
    { "src": "app.py", "use": "@vercel/python" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/validation-key.txt",
      "dest": "public/validation-key.txt"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ]
}
